# Affiliate Junction Secrets Template
# This file shows the structure of secrets needed for deployment
# DO NOT commit actual secrets to version control

# For Kubernetes deployment, these will be stored in a Kubernetes Secret
# For local development, copy to .env file

# HCD/Cassandra Database Credentials
HCD_USERNAME: cassandra
HCD_PASSWORD: <generate-strong-password>

# Presto/watsonx.data Credentials
PRESTO_USERNAME: ibmlhadmin
PRESTO_PASSWORD: <from-watsonx.data-console>

# Web UI Authentication
WEB_AUTH_PASSWD: watsonx.data

# IBM Cloud Mission Control License
# Obtain from IBM Cloud console
MC_LICENSE_ID: <your-mission-control-license-id>

# Notes:
# - HCD_PASSWORD: Generate a strong password for HCD deployment
# - PRESTO_PASSWORD: Obtain from watsonx.data instance credentials
# - MC_LICENSE_ID: Required for Mission Control deployment on IBM Cloud
# - All passwords should be at least 12 characters with mixed case, numbers, and symbols